datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  email    String? @unique
  username String? @unique
  isAdmin  Boolean @default(false)

  paymentProcessorUserId        String?   @unique
  lemonSqueezyCustomerPortalUrl String? // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus            String? // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan              String? // 'hobby', 'pro'
  datePaid                      DateTime?
  credits                       Int       @default(3)

  gptResponses        GptResponse[]
  contactFormMessages ContactFormMessage[]
  tasks               Task[]
  files               File[]
  alumniDestinations  AlumniDestination[]
  AssessmentJob       AssessmentJob[]
  apiKeys             ApiKey[]
}

model GptResponse {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String

  content String
}

model Task {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  description String
  time        String  @default("1")
  isDone      Boolean @default(false)
}

model File {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  name  String
  type  String
  s3Key String
}

model DailyStats {
  id   Int      @id @default(autoincrement())
  date DateTime @unique @default(now())

  totalViews                Int    @default(0)
  prevDayViewsChangePercent String @default("0")
  userCount                 Int    @default(0)
  paidUserCount             Int    @default(0)
  userDelta                 Int    @default(0)
  paidUserDelta             Int    @default(0)
  totalRevenue              Float  @default(0)
  totalProfit               Float  @default(0)

  sources PageViewSource[]
}

model PageViewSource {
  name String
  date DateTime @default(now())

  dailyStats   DailyStats? @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId Int?

  visitors Int

  @@id([date, name])
}

model Logs {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  message String
  level   String
}

model ContactFormMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  content   String
  isRead    Boolean   @default(false)
  repliedAt DateTime?
}

model AssessmentJob {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  handbookUrl  String
  courseCode   String?
  status       String  @default("queued") // queued | processing | complete | failed
  errorMessage String?

  // Result fields (populated when status = "complete")
  programName   String?
  score         Int?
  maxScore      Int?
  riskBand      String?
  thresholds    Json?
  dimensions    Json?
  reportJson    Json?    // Full report content as JSON
  syllabusJson  Json?    // Mapped syllabus structures, prerequisites, flow rates, and IRA matrices

  // Snapshot tracking
  snapshots     AssessmentSnapshot[]
}

// Cross-institutional benchmarking
model Institution {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  name          String
  code          String   @unique   // e.g. "unimelb", "usyd", "unsw"
  country       String   @default("AU")

  assessments   InstitutionalAssessment[]
  apiKeys       ApiKey[]
}

model InstitutionalAssessment {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String

  programName   String
  programCode   String
  level         String?            // Bachelor, Master, PhD
  handbookUrl   String?

  score         Int
  maxScore      Int     @default(36)
  riskBand      String
  thresholds    Json?
  dimensions    Json?
  snapshotDate  DateTime @default(now())

  @@unique([institutionId, programCode])
}

model AssessmentSnapshot {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())

  job           AssessmentJob @relation(fields: [jobId], references: [id])
  jobId         String

  programName   String
  programCode   String?
  score         Int
  maxScore      Int
  riskBand      String
  thresholds    Json?
  dimensions    Json?
  snapshotDate  DateTime

  @@index([jobId])
  @@index([programCode])
}

model ApiKey {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String

  user          User?     @relation(fields: [userId], references: [id])
  userId        String?

  name          String             // e.g. "Production key for USyd"
  keyHash       String   @unique   // bcrypt/scrypt hash of the API key
  keyPrefix     String             // First 8 chars for display (e.g. "dfva_abc...")
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime?

  @@index([institutionId])
  @@index([userId])
}

// Market Validation — feat-006
model MarketValidationSignal {
  id               String   @id @default(uuid())
  source           String // "ListEdTech", "RFP.wiki", "InnoTechToday", etc.
  excerpt          String // Key claim or quote (max 500 chars)
  url              String // Link to original source
  dateDiscovered   DateTime
  credibilityScore Int // 1-5
  category         String // "market_convergence", "analytics_gap", "data_architecture", etc.
  relevantClaim    String // 1-line summary of what this validates about DFVA
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompetitiveEvent {
  id                 String   @id @default(uuid())
  competitor         String // "Coursedog", "CourseLoop", "Modern Campus", "Curriculog"
  eventType          String // "PRODUCT_LAUNCH", "FUNDING", "PARTNERSHIP", "ACQUISITION", "ANNOUNCEMENT"
  title              String
  description        String
  source             String // URL or reference
  url                String?
  dateOccurred       DateTime
  dateDiscovered     DateTime
  impactScore        Int // 1-5
  marketWindowEffect String // "OPENING", "NEUTRAL", "CLOSING"
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MarketWindowSnapshot {
  id                 String   @id @default(uuid())
  status             String // "OPEN", "NARROWING", "CLOSED", "MISSED"
  urgencyText        String // 1-2 sentence assessment
  keyThreats         Json // e.g. ["Coursedog LMI shipping Q3 2026"]
  recommendedActions Json // e.g. ["Accelerate DFVA market positioning"]
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

model AlumniDestination {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  programCode     String
  graduationYear  Int
  jobTitle        String
  employer        String?
  industryCluster String // e.g. "BioSciences", "Software/IT"

  @@index([programCode])
  @@index([industryCluster])
}

model CourseInterventionOwner {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  assessmentJobId String
  courseCode      String
  dimensionId     Int

  ownerName  String
  ownerEmail String
  status     String    @default("assigned") // assigned | in_progress | completed
  targetDate DateTime?

  @@unique([assessmentJobId, courseCode, dimensionId])
}
