{
  "name": "dfva-scripts",
  "version": "1.0.0",
  "private": true,
  "description": "DFVA batch pipeline validation and tooling",
  "scripts": {
    "dfva:gen": "npx tsx dfva-generate.ts",
    "dfva:gen-content": "npx tsx dfva-content-generate.ts",
    "dfva:gen-assessments": "npx tsx dfva-build-assessments.ts",
    "dfva:check": "npx tsx dfva-check.ts && npx tsx dfva-content-check.ts && npx tsx dfva-registry-check.ts && npx tsx dfva-assessments-check.ts",
    "dfva:assessments-check": "npx tsx dfva-assessments-check.ts",
    "dfva:check-registry": "npx tsx dfva-registry-check.ts",
    "dfva:content-check": "npx tsx dfva-content-check.ts",
    "dfva:completeness": "npx tsx check-course-completeness.ts",
    "dfva:report-lint": "npx tsx check-report-format.ts",
    "dfva:sync-skill": "cp ../dfva/dist/claude-skill/SKILL.md ~/.claude/skills/dfva/SKILL.md"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
